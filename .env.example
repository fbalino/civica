# Required — Neon Postgres connection string
# Obtain from https://console.neon.tech → your project → Connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Optional — Congress.gov API key for US legislative data
# Defaults to "DEMO_KEY" (rate-limited) when not set
# Obtain from https://api.congress.gov/sign-up/
CONGRESS_API_KEY=DEMO_KEY
